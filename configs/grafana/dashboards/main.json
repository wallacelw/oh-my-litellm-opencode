      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(litellm_spend_metric_total{model=~\"$model\"}[$__range]))",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$",
