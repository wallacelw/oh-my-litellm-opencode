{
  "title": "oh-my-litellm-opencode",
  "uid": "oh-my-litellm-opencode",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(litellm_deployment_total_requests_total, litellm_model_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "api_key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(litellm_proxy_total_requests_metric_total, api_key_alias)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "At-a-glance",
      "description": "Snapshot of live proxy load: in-flight requests, request/token rates, and deployment count. Narrow with the model and api_key variables at the top.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Requests",
      "description": "Number of requests currently in flight (being processed) by the proxy right now. Spikes indicate burst load or slow upstream models.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "litellm_in_flight_requests",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "avg_over_time(litellm_in_flight_requests[7d:1m])",
          "refId": "B",
          "legendFormat": "",
          "hide": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RPM",
      "description": "Requests per minute over the last 1 minute, summed across all selected models and API keys. A hidden 7-day average is recorded for trending.",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_total_requests_metric_total{requested_model=~\"$model\",api_key_alias=~\"$api_key\"}[1m])) * 60",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "litellm:rpm:7d_avg",
          "refId": "B",
          "legendFormat": "",
          "hide": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/min",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "TPM",
      "description": "Total tokens per minute (input + output) over the last 1 minute, summed across selected models and API keys.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_total_tokens_metric_total{model=~\"$model\",api_key_alias=~\"$api_key\"}[1m])) * 60",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "litellm:tpm:7d_avg",
          "refId": "B",
          "legendFormat": "",
          "hide": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tok/min",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Models Deployed",
      "description": "Count of distinct model types currently registered and health-checked by the proxy. Uses litellm_deployment_state, refreshed every 5 min by the background health check. A drop means a model type has no healthy deployment.",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (litellm_model_name) (litellm_deployment_state{litellm_model_name=~\"$model\"}))",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Latency",
      "description": "Streaming latency percentiles per model. P50 is the typical experience, P95 is the slow tail. Compare against the 7d avg line to spot regressions.",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "TTFT by model",
      "description": "Time To First Token in seconds — how long until the first token of a response arrives. P50 = median, P95 = slow tail, 7d avg = baseline. Rising TTFT means users wait longer before seeing output.",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, model) (rate(litellm_llm_api_time_to_first_token_metric_bucket{model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])))",
          "refId": "A",
          "legendFormat": "P50",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(litellm_llm_api_time_to_first_token_metric_bucket{model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])))",
          "refId": "B",
          "legendFormat": "P95",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "litellm:ttft_p95:7d_avg",
          "refId": "C",
          "legendFormat": "7d avg",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "TPOT by model",
      "description": "Time Per Output Token in seconds — gap between consecutive tokens during streaming. Lower is smoother and faster streaming. P50, P95, and 7d avg shown.",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, litellm_model_name) (rate(litellm_deployment_latency_per_output_token_bucket{litellm_model_name=~\"$model\",api_key_alias=~\"$api_key\"}[5m])))",
          "refId": "A",
          "legendFormat": "P50",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, litellm_model_name) (rate(litellm_deployment_latency_per_output_token_bucket{litellm_model_name=~\"$model\",api_key_alias=~\"$api_key\"}[5m])))",
          "refId": "B",
          "legendFormat": "P95",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "litellm:tpot_p50:7d_avg",
          "refId": "C",
          "legendFormat": "7d avg",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "Cost & Budget",
      "description": "Spend accumulation and remaining budget per API key.",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Total cost (all models)",
      "description": "Cumulative USD spent across all selected models and API keys since metrics started. This is a running total, not a rate.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(litellm_spend_metric_total{model=~\"$model\",api_key_alias=~\"$api_key\"})",
          "refId": "A",
          "legendFormat": "",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Total cost per model",
      "description": "Cumulative USD spend over time, one colored curve per model. Steeper slopes mean faster spend. The legend table shows each model's latest total.",
      "gridPos": {
        "x": 6,
        "y": 15,
        "w": 18,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (model) (litellm_spend_metric_total{model=~\"$model\",api_key_alias=~\"$api_key\"})",
          "refId": "A",
          "legendFormat": "{{model}}",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Throughput",
      "description": "Request and token rates over time per model, with a 7-day average baseline for comparison.",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "RPM by model",
      "description": "Requests per minute per model (Current) vs the 7-day average (7d avg). Current above the baseline means elevated load; below means lighter usage.",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (requested_model) (rate(litellm_proxy_total_requests_metric_total{requested_model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])) * 60",
          "refId": "A",
          "legendFormat": "Current",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "avg_over_time((sum by (requested_model) (rate(litellm_proxy_total_requests_metric_total{requested_model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])) * 60)[7d:5m])",
          "refId": "B",
          "legendFormat": "7d avg",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/min",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "TPM by model",
      "description": "Tokens per minute per model (Current) vs the 7-day average (7d avg). Useful for spotting which model is driving token consumption.",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_total_tokens_metric_total{model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])) * 60",
          "refId": "A",
          "legendFormat": "Current",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "avg_over_time((sum by (model) (rate(litellm_total_tokens_metric_total{model=~\"$model\",api_key_alias=~\"$api_key\"}[5m])) * 60)[7d:5m])",
          "refId": "B",
          "legendFormat": "7d avg",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tok/min",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Deployment & Health",
      "description": "Model health state and total request volume per model.",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Model health (successful responses)",
      "description": "Total successful responses per model from litellm_deployment_success_responses_total. Green = model is healthy and has served traffic. Red/empty = no successful responses yet.",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum by (litellm_model_name) (litellm_deployment_success_responses_total{litellm_model_name=~\"$model\"})",
          "refId": "A",
          "legendFormat": "{{litellm_model_name}}",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Total requests per model",
      "description": "Cumulative request count per model over time, one colored line per model. Steeper slopes mean heavier usage. Flat lines mean no traffic.",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (litellm_model_name) (litellm_deployment_total_requests_total{litellm_model_name=~\"$model\"})",
          "refId": "A",
          "legendFormat": "{{litellm_model_name}}",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
