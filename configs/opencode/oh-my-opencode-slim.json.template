  "fallback": {
    "enabled": true,
    "timeoutMs": 15000,
    "retryDelayMs": 500,
    "retry_on_empty": true
  },
  "council": {
    "presets": {
      "default": {
        "alpha": { "model": "LiteLLM/glm-5.2", "variant": "high", "prompt": "Focus on deep reasoning, logical correctness, and identifying subtle bugs or edge cases." },
        "beta":  { "model": "LiteLLM/glm-5.2", "variant": "high", "prompt": "Focus on architecture, maintainability, trade-offs, and long-term implications." },
        "gamma": { "model": "LiteLLM/glm-5.2", "variant": "high", "prompt": "Focus on practical implementation, cost-efficiency, and concrete verification steps." }
      }
    },
    "timeout": 180000,
    "default_preset": "default",
    "councillor_execution_mode": "parallel",
    "councillor_retries": 3
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 60,
    "zellij_pane_mode": "agent-tab"
  },
  "backgroundJobs": {
    "maxSessionsPerAgent": 2,
    "readContextMinLines": 10,
    "readContextMaxFiles": 8
  },
  "companion": {
    "enabled": false,
    "position": "bottom-right",
    "size": "medium",
    "gifPack": "default",
    "loopStyle": "classic",
    "speed": 1,
    "debug": false
  }
