# ─────────────────────────────────────────────────────────────────────────────
# LiteLLM Config Template (Single-Key Example)
#
# This is a REFERENCE template showing single-key configuration.
# The actual config is GENERATED by scripts/generate_config.sh which creates
# N deployments per model (one for each HUAWEI_MAAS_API_KEY_N).
#
# Do NOT edit this file directly. Instead:
#   1. Run scripts/1_init_env.sh to set up .env with your MaaS API keys
#   2. Run scripts/2_generate_config.sh to generate the actual config
#
# Generated config will use: os.environ/HUAWEI_MAAS_API_KEY_0, _1, _2, etc.
# The _0 suffix matches the .env format written by init_env.sh.
# ─────────────────────────────────────────────────────────────────────────────

model_list:

  # ───────── Huawei MaaS Models ───────────

  - model_name: glm-5.2
    litellm_params:
      model: openai/glm-5.2
      api_base: os.environ/HUAWEI_MAAS_API_BASE
      api_key: os.environ/HUAWEI_MAAS_API_KEY_0
      tpm: 198000
      rpm: 100
    model_info:
